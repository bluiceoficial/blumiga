{
    "name": "bluice/blufast",
    "version": "0.1.0",
    "description": "Blumiga é um framework PHP leve e de alta performance, projetado para o desenvolvimento rápido, limpo e seguro de aplicações web.",
    "keywords": ["framework","php","blumiga","alta-performance","leve","mvc","rotas","desenvolvimento-rapido","clean-code"],
    "type": "project",
    "authors": [
        {
            "name": "Murilo Gomes Julio",
            "email": "murilo@bluice.com.br",
            "homepage": "https://www.bluice.com.br"
        }
    ],
    "_comment": [
        "Copyright (C) 2026 Murilo Gomes Julio"
    ],
    "license": "GPL-2.0-only",
    "autoload": {
        "psr-4": {
            "Blumiga\\": "libs/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "scripts": {
        "post-root-package-install": [
            "@php -r \"file_exists('config/config.php') || copy('config/config.example.php', 'config/config.php');\""
        ]
    }
}
