function criarMiddleware(string $nome): void {
    $diretorio = __DIR__ . '/app/middleware';
    if (!is_dir($diretorio)) {
        mkdir($diretorio, 0755, true);
    }

    $caminhoCompleto = "{$diretorio}/{$nome}.php";

    $template = "<?php
// Middleware: {$nome}
// Gerado em: " . date('Y-m-d H:i:s') . "

namespace Blumiga\\middleware\\{$nome};

if (!defined('blumiga')) exit;

function run(callable \$next, mixed \$param = null): void {
    \$next();
}
";

    file_put_contents($caminhoCompleto, $template);
    echo "\033[32m✔ Middleware criado em:\033[0m app/middleware/{$nome}.php\n";

    echo "\033[33m📌 Use-o em rotas: routeGET('/rota', 'ctrl@func', 'nome', ['{$nome}@run']);\033[0m\n";
}

function executarMigrations() {
    echo "\033[33mBuscando e executando migrations funcionais...\033[0m\n";
    $diretorio = __DIR__ . '/app/database/migrations';

    if (!is_dir($diretorio)) {
        die("Nenhuma migration encontrada.\n");
    }

    $arquivos = glob("{$diretorio}/*.php");
    sort($arquivos);

    foreach ($arquivos as $arquivo) {
        echo "Running UP: " . basename($arquivo) . "...\n";
        $migration = require $arquivo;

        if (isset($migration['up']) && is_callable($migration['up'])) {
            $migration['up']();
        }
    }

    echo "\n\033[32m✔ Migrations executadas com sucesso!\033[0m\n";
}

function executarRollbackMigrations() {
    echo "\033[33mIniciando Rollback das Migrations Funcionais (Ordem Reversa)...\033[0m\n";
    $diretorio = __DIR__ . '/app/database/migrations';

    if (!is_dir($diretorio)) {
        die("Nenhuma migration encontrada.\n");
    }

    $arquivos = glob("{$diretorio}/*.php");
    rsort($arquivos);

    foreach ($arquivos as $arquivo) {
        echo "Running DOWN: " . basename($arquivo) . "...\n";
        $migration = require $arquivo;

        if (isset($migration['down']) && is_callable($migration['down'])) {
            $migration['down']();
        } else {
            echo "\033[31mErro: Função 'down' não encontrada ou inválida em " . basename($arquivo) . "\033[0m\n";
        }
    }

    echo "\n\033[32m✔ Rollback concluído!\033[0m\n";
}

function executarSeeders(?string $especifico = null): void {
    $diretorio = __DIR__ . '/app/database/seeders';

    if (!is_dir($diretorio)) {
        die("Nenhum seeder encontrado.\n");
    }

    if ($especifico) {
        $arquivo = "{$diretorio}/{$especifico}Seeder.php";
        if (file_exists($arquivo)) {
            echo "Seeding: " . basename($arquivo) . "...\n";
            $seeder = require $arquivo;
            if (isset($seeder['run']) && is_callable($seeder['run'])) {
                $seeder['run']();
            }
        } else {
            echo "\033[31mSeeder '{$especifico}Seeder.php' não encontrado.\033[0m\n";
        }
    } else {
        echo "\033[33mExecutando todos os seeders funcionais encontrados...\033[0m\n";
        $arquivos = glob("{$diretorio}/*.php");
        sort($arquivos);
        foreach ($arquivos as $arquivo) {
            echo "Seeding: " . basename($arquivo) . "...\n";
            $seeder = require $arquivo;
            if (isset($seeder['run']) && is_callable($seeder['run'])) {
                $seeder['run']();
            }
        }
    }

    echo "\n\033[32m✔ Seeders executados com sucesso!\033[0m\n";
}

function executarRollbackSeeders(?string $especifico = null): void {
    $diretorio = __DIR__ . '/app/database/seeders';

    if (!is_dir($diretorio)) {
        die("Nenhum seeder encontrado.\n");
    }

    if ($especifico) {
        $arquivo = "{$diretorio}/{$especifico}Seeder.php";
        if (file_exists($arquivo)) {
            echo "Rolling back Seeder: " . basename($arquivo) . "...\n";
            $seeder = require $arquivo;
            if (isset($seeder['down']) && is_callable($seeder['down'])) {
                $seeder['down']();
            }
        } else {
            echo "\033[31mSeeder '{$especifico}Seeder.php' não encontrado.\033[0m\n";
        }
    } else {
        echo "\033[33mLimpando todos os seeders funcionais (Ordem Reversa)...\033[0m\n";
        $arquivos = glob("{$diretorio}/*.php");
        rsort($arquivos);
        foreach ($arquivos as $arquivo) {
            echo "Rolling back Seeder: " . basename($arquivo) . "...\n";
            $seeder = require $arquivo;
            if (isset($seeder['down']) && is_callable($seeder['down'])) {
                $seeder['down']();
            }
        }
    }

    echo "\n\033[32m✔ Rollback concluído!\033[0m\n";
}
